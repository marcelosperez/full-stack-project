<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>

<body>
  <h1><%= title %></h1>
  
  <p>Current second: <%= seconds %></p>

  <% if (seconds % 2 === 0) { %>
    <ul>
      <% for (let i = 0; i < items.length; i++) { %>
        <li>Item #<%= i + 1 %>: <%= items[i] %></li>
      <% } %>
    </ul>
  <% } else { %>
    <p>No items to display</p>
  <% } %>

  </body>

</html>